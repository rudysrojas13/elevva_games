generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("user") // "user", "admin"
  balance      Float    @default(0.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  options     String   @default("") // JSON: [{"label":"7 días","price":8900},{"label":"30 días","price":11240}]
  category    String   // "PS4", "PS5", "Suscripciones"
  imageUrl    String
  stock       Int      @default(10)
  active      Boolean  @default(true)
  costUsd     Float    @default(0.0)
  trm         Float    @default(4000.0)
  markupPercent Float  @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  total       Float
  status      String   @default("Pendiente") // "Pendiente", "Completado", "Cancelado"
  credentials String   @default("") // ej: "correo@gmail.com:clave123 | Instrucciones: ..."
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
